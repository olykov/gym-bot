# Copy to .env and fill in. Never commit the real .env.

# --- Database (Postgres container) ---
DB_USER=
DB_PASSWORD=
DB_HOST=gymbot_db
DB_NAME=
DB_PORT=5432

# --- Redis ---
REDIS_PASSWORD=
REDIS_HOST=gymbot_redis
REDIS_PORT=6379

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
WEB_APP_URL=

# --- Admin API auth ---
JWT_SECRET=

# --- Integrations (optional) ---
GOOGLE_SHEET_ID=
NEXTAUTH_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
